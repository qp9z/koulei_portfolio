---
import { site } from "../data/site";
import Icon from "./Icon.astro";

const links = [
  { label: "About", href: "#about" },
  { label: "Skills", href: "#skills" },
  { label: "Work", href: "#work" },
  { label: "Journey", href: "#journey" },
  { label: "Contact", href: "#contact" },
];
---
<header class="nav" id="nav">
  <div class="container nav-inner">
    <a href="#top" class="brand" aria-label={`${site.brand} — home`}>
      <span class="brand-mark">{site.brand.charAt(0)}</span>
      <span class="brand-name">{site.brand}<span class="brand-dot">.dev</span></span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="nav-actions">
      <button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle color theme">
        <span class="sun"><Icon name="sun" size={18} /></span>
        <span class="moon"><Icon name="moon" size={18} /></span>
      </button>
      <a href="#contact" class="btn btn-primary nav-cta">Let's talk</a>
      <button id="menu-toggle" class="icon-btn menu-btn" type="button" aria-label="Open menu" aria-expanded="false">
        <Icon name="menu" size={20} />
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    {links.map((l) => <a href={l.href} class="mobile-link">{l.label}</a>)}
    <a href="#contact" class="btn btn-primary mobile-cta">Let's talk</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
    border-bottom: 1px solid transparent;
  }
  .nav.scrolled {
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(14px) saturate(1.4);
    border-bottom-color: var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 800; }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 34px; height: 34px;
    border-radius: 10px;
    color: var(--on-accent);
    background: var(--grad);
    font-size: 1.05rem;
    text-transform: uppercase;
    box-shadow: 0 6px 16px -6px rgba(0, 0, 0, 0.6);
  }
  .brand-name { color: var(--heading); font-size: 1.1rem; letter-spacing: -0.02em; }
  .brand-dot { color: var(--muted); font-weight: 600; }

  .nav-links { display: flex; gap: 4px; }
  .nav-links a {
    padding: 8px 14px;
    border-radius: 999px;
    color: var(--muted);
    font-weight: 500;
    font-size: 0.94rem;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .nav-links a:hover { color: var(--heading); background: var(--surface-2); }

  .nav-actions { display: flex; align-items: center; gap: 10px; }

  .icon-btn {
    display: grid;
    place-items: center;
    width: 44px; height: 44px;
    border-radius: 11px;
    color: var(--heading);
    background: var(--surface);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.15s ease;
  }
  .icon-btn:hover { border-color: var(--accent); transform: translateY(-1px); }
  .icon-btn:active { transform: scale(0.95); }

  #theme-toggle .moon { display: none; }
  :root[data-theme="light"] #theme-toggle .sun { display: none; }
  :root[data-theme="light"] #theme-toggle .moon { display: block; }

  .menu-btn { display: none; }

  .mobile-menu {
    position: absolute;
    top: var(--nav-h);
    left: 0; right: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 12px 24px 22px;
    background: color-mix(in srgb, var(--bg) 94%, transparent);
    backdrop-filter: blur(14px) saturate(1.4);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  .mobile-menu[hidden] { display: none; }
  .mobile-link {
    padding: 12px 8px;
    color: var(--text);
    font-weight: 500;
    border-bottom: 1px solid var(--border);
  }
  .mobile-cta { justify-content: center; margin-top: 12px; }

  @media (max-width: 860px) {
    .nav-links, .nav-cta { display: none; }
    .menu-btn { display: grid; }
  }
</style>

<script is:inline>
  (() => {
    const nav = document.getElementById("nav");
    const onScroll = () => nav.classList.toggle("scrolled", window.scrollY > 12);
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    const toggle = document.getElementById("theme-toggle");
    toggle.addEventListener("click", () => {
      const root = document.documentElement;
      const next = root.dataset.theme === "light" ? "dark" : "light";
      root.dataset.theme = next;
      localStorage.setItem("theme", next);
      document
        .querySelector('meta[name="theme-color"]')
        ?.setAttribute("content", next === "light" ? "#f5f5f6" : "#0a0a0c");
    });

    const menuBtn = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const setMenu = (open) => {
      menu.hidden = !open;
      menuBtn.setAttribute("aria-expanded", String(open));
    };
    menuBtn.addEventListener("click", () => setMenu(menu.hidden));
    menu.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setMenu(false)));
  })();
</script>
