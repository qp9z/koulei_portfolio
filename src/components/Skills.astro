---
import { skills } from "../data/site";
import Icon from "./Icon.astro";
---
<section id="skills" class="section skills-section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Toolbox</span>
      <h2 class="section-title">Skills & technologies</h2>
      <p class="section-sub">The stack I reach for to design, build, and ship — from mobile to web.</p>
    </div>

    <div class="skills-grid">
      {skills.map((group, i) => (
        <div class="skill-card card reveal" style={`--delay:${i * 80}ms`}>
          <h3 class="skill-group">{group.group}</h3>
          <ul class="skill-list">
            {group.items.map((item) => (
              <li><Icon name="check" size={15} /> {item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-section {
    background:
      linear-gradient(180deg, transparent, color-mix(in srgb, var(--bg-soft) 60%, transparent), transparent);
  }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .skill-card {
    padding: 24px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .skill-card:hover { transform: translateY(-4px); border-color: var(--border-strong); }
  .skill-group {
    font-size: 1.05rem;
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid var(--border);
    color: var(--heading);
  }
  .skill-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 11px; }
  .skill-list li {
    display: flex;
    align-items: center;
    gap: 9px;
    color: var(--text);
    font-weight: 500;
    font-size: 0.96rem;
  }
  .skill-list :global(svg) { color: var(--accent-2); flex-shrink: 0; }

  @media (max-width: 900px) { .skills-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 460px) { .skills-grid { grid-template-columns: 1fr; } }
</style>
