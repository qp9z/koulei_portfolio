---
import { projects } from "../data/site";
import Icon from "./Icon.astro";

// Featured first, keep original order otherwise.
const ordered = [...projects].sort((a, b) => Number(b.featured) - Number(a.featured));
---
<section id="work" class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Selected work</span>
      <h2 class="section-title">Projects I've built</h2>
      <p class="section-sub">A mix of shipped apps and experiments. Each one taught me something worth keeping.</p>
    </div>

    <div class="proj-grid">
      {ordered.map((p, i) => (
        <article class={`proj card reveal${p.featured ? " featured" : ""}`} style={`--delay:${(i % 3) * 90}ms`}>
          <div class="proj-head">
            <div class="proj-glyph">{p.name.charAt(0)}</div>
            <div class="proj-links">
              {p.links.code && (
                <a href={p.links.code} target="_blank" rel="noopener" aria-label={`${p.name} source code`}>
                  <Icon name="github" size={18} />
                </a>
              )}
              {p.links.demo && (
                <a href={p.links.demo} target="_blank" rel="noopener" aria-label={`${p.name} live demo`}>
                  <Icon name="external" size={18} />
                </a>
              )}
            </div>
          </div>

          {p.featured && <span class="ribbon"><Icon name="spark" size={13} /> Featured</span>}

          <h3 class="proj-name">{p.name}</h3>
          <p class="proj-tagline">{p.tagline}</p>
          <p class="proj-desc">{p.description}</p>

          <div class="proj-tags">
            {p.tags.map((t) => <span class="chip">{t}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .proj-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .proj {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 24px;
    overflow: hidden;
    transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.28s ease;
  }
  .proj::after {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--grad);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .proj:hover {
    transform: translateY(-6px);
    border-color: var(--border-strong);
    box-shadow: var(--glow);
  }
  .proj:hover::after { opacity: 1; }
  .proj.featured { border-color: color-mix(in srgb, var(--accent) 40%, var(--border)); }

  .proj-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
  .proj-glyph {
    display: grid;
    place-items: center;
    width: 48px; height: 48px;
    border-radius: 13px;
    font-weight: 800;
    font-size: 1.3rem;
    color: var(--accent-2);
    background: var(--accent-soft);
    border: 1px solid var(--border);
  }
  .proj-links { display: flex; gap: 6px; }
  .proj-links a {
    display: grid;
    place-items: center;
    width: 40px; height: 40px;
    border-radius: 10px;
    color: var(--muted);
    border: 1px solid var(--border);
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
  }
  .proj-links a:hover { color: var(--heading); border-color: var(--accent); transform: translateY(-2px); }
  .proj-links a:active { transform: scale(0.94); }

  .ribbon {
    position: absolute;
    top: 22px;
    right: 88px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent-2);
  }

  .proj-name { font-size: 1.25rem; }
  .proj-tagline { margin-top: 4px; color: var(--accent-2); font-size: 0.86rem; font-weight: 600; }
  .proj-desc { margin-top: 12px; color: var(--muted); font-size: 0.95rem; flex: 1; }
  .proj-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }

  @media (max-width: 900px) { .proj-grid { grid-template-columns: repeat(2, 1fr); } .ribbon { right: 80px; } }
  @media (max-width: 620px) { .proj-grid { grid-template-columns: 1fr; } }
</style>
